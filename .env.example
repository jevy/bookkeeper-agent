# AWS_REGION=us-east-1
# S3_BUCKET=bookkeeper-emails-jevy
# SES_FROM_ADDRESS=digest@bookkeeper.jevy.org
# DIGEST_TO_ADDRESS=you@example.com
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
