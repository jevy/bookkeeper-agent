# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# OpenRouter (for categorizer)
OPENROUTER_API_KEY=sk-or-...

# Brave Search (optional, for categorizer web search tool)
BRAVE_API_KEY=BSA...

# Additional context for the categorizer agent (optional)
# ADDITIONAL_CONTEXT_PROMPT=We are a family of 4 with 2 kids. We live in Montreal...

